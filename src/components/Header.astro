---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
---

<header
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
    transparent ? 'bg-transparent' : 'bg-white/95 backdrop-blur-sm border-b border-gray-100 shadow-sm',
  ]}
  id="header"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" fill="white"/>
          </svg>
        </div>
        <span class="font-bold text-lg text-gray-900">NurseAbroad</span>
      </a>

      <!-- Nav -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/#features" class="text-sm font-medium text-gray-600 hover:text-primary-600 transition-colors">Features</a>
        <a href="/#how-it-works" class="text-sm font-medium text-gray-600 hover:text-primary-600 transition-colors">How it works</a>
        <a href="/#countries" class="text-sm font-medium text-gray-600 hover:text-primary-600 transition-colors">Countries</a>
      </nav>

      <!-- CTA -->
      <a
        href="https://play.google.com/store/apps/details?id=app.nurseabroad"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold rounded-lg transition-colors"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18.5v-13c0-.83.97-1.29 1.6-.76l10.15 6.5c.55.35.55 1.17 0 1.52L4.6 19.26C3.97 19.79 3 19.33 3 18.5z"/></svg>
        Get the app
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.remove('bg-transparent');
      header?.classList.add('bg-white/95', 'backdrop-blur-sm', 'border-b', 'border-gray-100', 'shadow-sm');
    }
  });
</script>
